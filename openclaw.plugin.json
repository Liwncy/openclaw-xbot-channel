{
  "id": "xbot",
  "name": "Xbot",
  "channels": ["xbot"],
  "contracts": {
    "tools": ["xbot_chat_history"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "enabled": { "type": "boolean" },
      "wechatApiBaseUrl": {
        "type": "string",
        "description": "xchatbot WeChat API base URL, e.g. https://your-worker.example.com"
      },
      "chatLogApiBaseUrl": {
        "type": "string",
        "description": "xchatbot admin base URL for chat log query; defaults to wechatApiBaseUrl"
      },
      "chatLogAdminToken": {
        "type": "string",
        "description": "Bearer token for xchatbot /admin/chat-log/query, usually same as xchatbot ADMIN_TOKEN"
      },
      "botWechatId": {
        "type": "string",
        "description": "Bot wxid for group @mention detection"
      },
      "botWechatName": {
        "type": "string",
        "description": "Bot display name shown in channel status"
      },
      "dmPolicy": {
        "type": "string",
        "enum": ["open", "allowlist", "disabled"]
      },
      "groupPolicy": {
        "type": "string",
        "enum": ["open", "allowlist", "disabled"]
      },
      "allowFrom": {
        "type": "array",
        "items": { "type": "string" }
      },
      "groupAllowFrom": {
        "type": "array",
        "items": { "type": "string" }
      },
      "requireMention": {
        "type": "boolean",
        "default": true,
        "description": "Legacy: when groupReplyMode unset, true→mention mode, false→all"
      },
      "groupReplyMode": {
        "type": "string",
        "enum": ["mention", "all"],
        "description": "mention: accumulate all group msgs, reply only on @/name; all: reply every msg"
      },
      "historyLimit": {
        "type": "number",
        "default": 50,
        "description": "Pending group history window size"
      },
      "historyForce": {
        "type": "boolean",
        "default": true,
        "description": "When pending window is full, silently flush into session (NO_REPLY, no WeChat send)"
      },
      "blockStreaming": { "type": "boolean" },
      "allowTool": { "type": "boolean" },
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string" }
          }
        }
      }
    }
  },
  "channelConfigs": {
    "xbot": {
      "schema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "enabled": { "type": "boolean" },
          "wechatApiBaseUrl": { "type": "string" },
          "chatLogApiBaseUrl": { "type": "string" },
          "chatLogAdminToken": { "type": "string" },
          "botWechatId": { "type": "string" },
          "botWechatName": { "type": "string" },
          "dmPolicy": {
            "type": "string",
            "enum": ["open", "allowlist", "disabled"]
          },
          "groupPolicy": {
            "type": "string",
            "enum": ["open", "allowlist", "disabled"]
          },
          "allowFrom": {
            "type": "array",
            "items": { "type": "string" }
          },
          "groupAllowFrom": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requireMention": { "type": "boolean" },
          "groupReplyMode": {
            "type": "string",
            "enum": ["mention", "all"]
          },
          "historyLimit": { "type": "number" },
          "historyForce": { "type": "boolean" },
          "blockStreaming": { "type": "boolean" },
          "allowTool": { "type": "boolean" },
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
